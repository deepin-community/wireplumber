From c2b96ebb395a8e9f97e728cff461d480446b94cb Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Barnab=C3=A1s=20P=C5=91cze?= <pobrn@protonmail.com>
Date: Fri, 20 Mar 2026 20:30:44 +0100
Subject: [PATCH] m-lua-scripting: impl_module_new(): fix property list memory
 leak

The `properties` argument of `wp_impl_module_load()` is marked
"transfer none", thus the caller's reference remains valid and
must be disposed of.

Fixes: ef29018c55f0 ("m-lua-scripting: Add WpImplModule bindings")
---
 modules/module-lua-scripting/api/api.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/modules/module-lua-scripting/api/api.c b/modules/module-lua-scripting/api/api.c
index 019f354f..815bb212 100644
--- a/modules/module-lua-scripting/api/api.c
+++ b/modules/module-lua-scripting/api/api.c
@@ -1691,7 +1691,7 @@ static int
 impl_module_new (lua_State *L)
 {
   const char *name, *args = NULL;
-  WpProperties *properties = NULL;
+  g_autoptr (WpProperties) properties = NULL;
 
   name = luaL_checkstring (L, 1);
 
-- 
2.20.1


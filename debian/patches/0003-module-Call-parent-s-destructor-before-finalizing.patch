From 478c9402fcb108a924b9368ec3a3724a4b98c6fe Mon Sep 17 00:00:00 2001
From: Julian Bouzas <julian.bouzas@collabora.com>
Date: Wed, 1 Apr 2026 08:36:06 -0400
Subject: [PATCH] module: Call parent's destructor before finalizing

This fixes memleaks when unreferencing the module.
---
 lib/wp/module.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/lib/wp/module.c b/lib/wp/module.c
index 0b7ff680..3461f81d 100644
--- a/lib/wp/module.c
+++ b/lib/wp/module.c
@@ -121,6 +121,8 @@ wp_impl_module_finalize (GObject * object)
 
   if (self->props)
     wp_properties_unref (self->props);
+
+  G_OBJECT_CLASS (wp_impl_module_parent_class)->finalize (object);
 }
 
 static void
-- 
2.20.1

